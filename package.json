{
  "name": "vanfolio",
  "version": "1.0.0",
  "description": "VanFolio — Professional Markdown Desktop App",
  "main": "out/main/main.js",
  "author": "VanFolio Contributors",
  "license": "MIT",
  "scripts": {
    "dev": "set ELECTRON_RUN_AS_NODE=&& electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit",
    "preview": "electron-vite preview",
    "package": "electron-builder"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.0",
    "@types/node": "^20.0.0",
    "@types/semver": "^7.7.1",
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0",
    "electron-vite": "^2.0.0",
    "png-to-ico": "^3.0.1",
    "png2icons": "^2.0.1",
    "rcedit": "^4.0.0",
    "sharp": "^0.34.5",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@codemirror/lang-markdown": "^6.0.0",
    "@codemirror/language": "^6.12.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.0.0",
    "@codemirror/view": "^6.40.0",
    "@google/generative-ai": "^0.21.0",
    "@lezer/highlight": "^1.2.3",
    "@types/markdown-it": "^14.0.0",
    "codemirror": "^6.0.0",
    "electron-log": "^5.0.0",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3",
    "html-to-docx": "^1.8.0",
    "jszip": "^3.10.0",
    "katex": "^0.16.0",
    "markdown-it": "^14.0.0",
    "markdown-it-anchor": "^9.0.0",
    "mermaid": "^11.0.0",
    "puppeteer-core": "^21.0.0",
    "semver": "^7.7.4"
  },
  "build": {
    "appId": "com.vanfolio.app",
    "productName": "VanFolio",
    "publish": null,
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "dir",
          "arch": ["x64"]
        },
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "license": "LICENSE",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "extraResources": [
      "LICENSE"
    ],
    "files": [
      "out/**/*",
      "!node_modules/mermaid/**/*",
      "!node_modules/@codemirror/**/*",
      "!node_modules/codemirror/**/*",
      "!node_modules/katex/src/**/*",
      "!node_modules/**/*.md",
      "!node_modules/**/*.ts",
      "!node_modules/**/test/**/*",
      "!node_modules/**/tests/**/*",
      "!node_modules/**/__tests__/**/*"
    ]
  }
}
